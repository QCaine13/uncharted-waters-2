  "normalizationTargets": [
    {
      "id": "normalize-port-catalog",
      "priority": 1,
      "description": "Create a canonical port catalog with English, Chinese, and Japanese names plus source references.",
      "dependsOn": ["current-regular-ports", "current-supply-ports", "cn-port-list", "gcgx-dkj2"],
      "output": "src/data/portCatalogData.ts or docs/data-governance/entities/ports.json"
    },
    {
      "id": "create-trade-good-catalog",
      "priority": 2,
      "description": "Build the missing trade-good table from original-game references.",
      "dependsOn": ["normalize-port-catalog", "gcgx-dkj2", "koei-wiki-trading"],
      "output": "src/data/tradeGoodData.ts"
    },
    {
      "id": "localize-building-menus",
      "priority": 3,
      "description": "Replace hard-coded building option labels with stable localization keys.",
      "dependsOn": ["current-buildings"],
      "output": "src/data/localizationData.ts"
    },
    {
      "id": "verify-ship-catalog",
      "priority": 4,
      "description": "Cross-check current ship stats and shipyard availability against guide data.",
      "dependsOn": ["current-ships", "current-shipyard-availability", "gcgx-dkj2"],
      "output": "docs/data-governance/audits/ships.md"
    },
    {
      "id": "model-discoveries",
      "priority": 5,
      "description": "Create a discovery catalog with coordinates, rewards, and report targets.",
